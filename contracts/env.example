# --- Django ---------------------------------------------------------------
DJANGO_SECRET_KEY=
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=contracts.ignitesolutions.click,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=https://contracts.ignitesolutions.click
DJANGO_TIME_ZONE=UTC

# Bootstrap admin user on first boot (optional; leave blank to create manually)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@ignitesolutions.click
DJANGO_SUPERUSER_PASSWORD=

# --- Postgres -------------------------------------------------------------
POSTGRES_DB=contracts
POSTGRES_USER=contracts
POSTGRES_PASSWORD=

# --- DocuSeal -------------------------------------------------------------
# Internal API endpoint (over the traefik_web network) and public host.
DOCUSEAL_URL=http://docuseal:3000
DOCUSEAL_PUBLIC_URL=https://sign.ignitesolutions.click
# Generate in DocuSeal UI: Settings -> API
DOCUSEAL_API_TOKEN=
# Shared secret; also configure it as a header/query param on the DocuSeal
# webhook pointing at https://contracts.ignitesolutions.click/webhooks/docuseal/
DOCUSEAL_WEBHOOK_SECRET=

# The counter-signer (you) added to every contract as the "Owner" role.
OWNER_SIGNER_NAME=
OWNER_SIGNER_EMAIL=

# --- MinIO ----------------------------------------------------------------
MINIO_ENDPOINT=http://minio:9000
MINIO_PUBLIC_ENDPOINT=https://minio.ignitesolutions.click
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=contracts
